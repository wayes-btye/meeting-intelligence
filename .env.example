# Find it in: Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Google API Key (for Gemini visual summary generation)
# Get your key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
